// Multi-tenant SaaS: organizations mirror Clerk organizations; memberships link Clerk users to orgs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  EMAIL
  WEBSITE_CHAT
  WHATSAPP
  INSTAGRAM
  FACEBOOK
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSenderType {
  CUSTOMER
  AGENT
  SYSTEM
}

model Organization {
  id           String   @id @default(cuid())
  clerkOrgId   String   @unique
  name         String
  slug         String   @unique
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   OrgMembership[]
  customers     Customer[]
  channels      Channel[]
  conversations Conversation[]
  messages      Message[]
  notes         Note[]
  tags          Tag[]

  @@index([clerkOrgId])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  createdAt      DateTime @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([organizationId])
}

model Channel {
  id             String      @id @default(cuid())
  organizationId String
  type           ChannelType
  name           String
  createdAt      DateTime    @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([organizationId])
}

model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  customerId     String
  channelId      String
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Restrict)
  messages     Message[]
  notes        Note[]
  tags         Tag[]

  @@index([organizationId])
  @@index([customerId])
  @@index([channelId])
}

model Message {
  id             String            @id @default(cuid())
  organizationId String
  conversationId String
  content        String            @db.Text
  direction      MessageDirection
  senderType     MessageSenderType
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
}

/// Internal agent notes on a conversation (not visible to customers).
model Note {
  id             String   @id @default(cuid())
  organizationId String
  conversationId String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String
  createdAt      DateTime @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model OrgMembership {
  id             String   @id @default(cuid())
  organizationId String
  clerkUserId    String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clerkUserId])
  @@index([clerkUserId])
}

/// Optional app-specific profile; Clerk remains source of truth for auth identity.
model UserProfile {
  clerkUserId String   @id
  email       String?
  displayName String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
